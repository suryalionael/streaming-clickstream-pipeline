# === Kafka ===
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_CLICKSTREAM=clickstream-events
KAFKA_TOPIC_DEAD_LETTER=clickstream-dead-letter
KAFKA_PARTITIONS=6
KAFKA_REPLICATION_FACTOR=1

# === Generator ===
EVENTS_PER_SECOND=50
NUM_USERS=1000
ABANDONMENT_RATE=0.7
CONVERSION_RATE=0.05
BURST_MODE=false
BURST_MULTIPLIER=3
BLACK_FRIDAY_MODE=false

# === Spark Streaming ===
SPARK_MASTER=local[*]
SPARK_BATCH_DURATION=10
SPARK_CHECKPOINT_DIR=/opt/spark/checkpoints
SPARK_WATERMARK_DELAY_MINUTES=60
SPARK_WINDOW_INTERVAL=5
SPARK_STARTING_OFFSETS=latest

# === MinIO (S3-compatible storage) ===
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=clickstream-lake

# === Delta Lake paths ===
DELTA_BRONZE_PATH=/opt/spark/data/bronze
DELTA_SILVER_PATH=/opt/spark/data/silver
DELTA_GOLD_PATH=/opt/spark/data/gold

# === Dashboard ===
DASHBOARD_REFRESH_INTERVAL=5
DUCKDB_PATH=/app/data/metrics.duckdb

# === Logging ===
LOG_LEVEL=INFO
LOG_FORMAT=json
